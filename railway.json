{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./config/Dockerfile"
  },
  "deploy": {
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetries": 3,
    "healthchecks": {
      "liveness": {
        "path": "/api/health",
        "initialDelaySeconds": 10,
        "periodSeconds": 30
      }
    }
  },
  "environment": [
    {
      "name": "PYTHONUNBUFFERED",
      "value": "1"
    },
    {
      "name": "LOG_LEVEL",
      "value": "INFO"
    }
  ]
}
